PROCESO QUE CALCULAELSUELDOCONCOMISIONESPORVENTAS
ESCRIBIR "INGRESE SUELDO BASE:"
LEER SUELDO
ESCRIBIR "INGRESE VENTA 1:"
LEER V1
ESCRIBIR "INGRESE VENTA 2:"
LEER V2
ESCRIBIR "INGRESE VENTA 3:"
LEER V3
SUMAVENTAS <- V1+V2+V3
COMISION <- SUMAVENTAS / 10
TOTAL = SUELDO + COMISION
ESCRIBIR "COMISION:", COMISION
ESCRIBIR "TOTAL A RECIBIR :" , TOTAL
FINPROCESO
