ALGORITMO INICIALES_PERSONA
    ESCRIBIR "DIGITE SU NOMBRE:"
    LEER NOMBRE
    ESCRIBIR "DIGITE PRIMER APELLIDO:"
    LEER APELLIDO1
    ESCRIBIR "DIGITE SEGUNDO APELLIDO:"
    LEER APELLIDO2
    
    // Subcadena toma el primer caracter (posicion 0 o 1 segun config)
    I1 = SUBCADENA(NOMBRE, 0, 0)
    I2 = SUBCADENA(APELLIDO1, 0, 0)
    I3 = SUBCADENA(APELLIDO2, 0, 0)
    
    ESCRIBIR "LAS INICIALES SON: ", MAYUS(I1), MAYUS(I2), MAYUS(I3)
FINALGORITMO
