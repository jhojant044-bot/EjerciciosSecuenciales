PROCESO CONVERTIRAMINUTOS
ESCRIBIR "PROGRAMA PARA CONVERTIR MINUTOS A HORAS , MINUTOS Y SEGUNDOS"
ESCRIBIR "."
ESCRIBIR "DIGITE LA CANTIDAD DE MINUTOS"
LEER MIN
HORAS = TRUNC(MIN / 60)
MINUTOS = MIN MOD 60
SEGUNDOS = MIN * 60
ESCRIBIR "HORAS: ", HORAS
ESCRIBIR "MINUTOS: ",MINUTOS 
ESCRIBIR "SEGUNDOS: ", SEGUNDOS
FINPROCESO
