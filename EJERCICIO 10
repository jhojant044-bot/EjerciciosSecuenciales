PROCESO NOTAFINAL
ESCRIBIR  "NOTA FINAL"
ESCRIBIR "INGRESE NOTA 1:"
LEER NOTA1
ESCRIBIR "INGRESE NOTA 2:"
LEER NOTA2
ESCRIBIR "INGRESE NOTA 3:"
LEER NOTA3
ESCRIBIR "INGRESE EXAMEN:"
LEER EXAMEN
ESCRIBIR "INGRESE TRABAJO:"
LEER TRABAJO
SUMA  = NOTA1 + NOTA2 + NOTA3
PROMEDIO = SUMA  / 3
NOTAFINAL <- (PROMEDIO * 55 /100) + (EXAMEN * 30 / 100) + (TRABAJO * 15 / 100)
ESCRIBIR "PROMEDIO:", PROMEDIO
ESCRIBIR "NOTA FINAL:" , NOTAFINAL
FINPROCESO
